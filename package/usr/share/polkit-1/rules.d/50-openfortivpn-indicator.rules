// Permite que usuários locais e ativos do grupo "sudo" liguem/desliguem
// APENAS o serviço openfortivpn-indicator.service sem digitar a senha
// a cada conexão. Qualquer outra unidade continua exigindo autenticação.
//
// Para exigir senha sempre, basta remover este arquivo — o indicador
// cai automaticamente para o pkexec (que pede a senha).
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units") {
        var unit = action.lookup("unit");
        if (unit == "openfortivpn-indicator.service" &&
            subject.local && subject.active &&
            subject.isInGroup("sudo")) {
            return polkit.Result.YES;
        }
    }
});
